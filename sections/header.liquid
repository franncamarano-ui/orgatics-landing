<nav class="site-nav">
  <div class="nav-left">
    <ul class="nav-links">
      <li><a href="{{ routes.root_url }}" {% if request.page_type == 'index' %}class="active"{% endif %}>Inicio</a></li>
      <li><a href="{{ routes.collections_url }}/all" {% if request.page_type == 'collection' %}class="active"{% endif %}>Catálogo</a></li>
      <li><a href="{{ routes.root_url }}pages/contacto" {% if request.page_type == 'page' and page.handle == 'contacto' %}class="active"{% endif %}>Contacto</a></li>
      <li><a href="{{ routes.root_url }}pages/rastreo" {% if request.page_type == 'page' and page.handle == 'rastreo' %}class="active"{% endif %}>Rastrea tu producto</a></li>
    </ul>
  </div>

  <a href="{{ routes.root_url }}" class="nav-logo">{{ shop.name }}</a>

  <div class="nav-right">
    <button class="nav-icon-btn" aria-label="Buscar" onclick="document.getElementById('search-bar').classList.toggle('open')">
      <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg>
    </button>
    <button class="nav-icon-btn" aria-label="Carrito" onclick="openCart()">
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span class="cart-count" id="cart-count">{{ cart.item_count }}</span>
    </button>
    <button class="nav-hamburger" onclick="toggleMobileMenu()" aria-label="Menú">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<div class="mobile-menu-overlay" id="mobile-overlay" onclick="closeMobileMenu()"></div>
<div class="mobile-menu" id="mobile-menu">
  <div class="mobile-menu-header">
    <span class="logo">{{ shop.name }}</span>
    <button class="mobile-menu-close" onclick="closeMobileMenu()">✕</button>
  </div>
  <ul>
    <li><a href="{{ routes.root_url }}">Inicio</a></li>
    <li><a href="{{ routes.collections_url }}/all">Catálogo</a></li>
    <li><a href="{{ routes.root_url }}pages/contacto">Contacto</a></li>
    <li><a href="{{ routes.root_url }}pages/rastreo">Rastrea tu producto</a></li>
    <li><a href="#suscribirse" class="cta-mobile">Suscribirse gratis →</a></li>
  </ul>
</div>

<div class="cart-overlay" id="cart-overlay" onclick="closeCart()"></div>
<div class="cart-drawer" id="cart-drawer">
  <div class="cart-drawer-header">
    <h3>Tu Carrito</h3>
    <button class="cart-close-btn" onclick="closeCart()">✕</button>
  </div>
  <div class="cart-drawer-body" id="cart-body">
    {% if cart.item_count == 0 %}
      <div class="cart-empty-icon">🛍️</div>
      <p>Tu carrito está vacío.<br>Explorá el catálogo para agregar productos.</p>
    {% else %}
      {% for item in cart.items %}
        <div style="display:flex;gap:12px;align-items:flex-start;width:100%;padding-bottom:16px;border-bottom:1px solid var(--border);">
          <img src="{{ item.image | img_url: '80x80' }}" style="width:56px;height:56px;border-radius:8px;object-fit:cover;">
          <div style="flex:1;">
            <strong style="font-size:13px;display:block;">{{ item.title }}</strong>
            <span style="font-size:12px;color:var(--muted);">Qty: {{ item.quantity }}</span>
          </div>
          <span style="font-size:14px;font-weight:700;">{{ item.line_price | money }}</span>
        </div>
      {% endfor %}
    {% endif %}
  </div>
  <div class="cart-drawer-footer">
    {% if cart.item_count > 0 %}
      <div style="display:flex;justify-content:space-between;font-weight:700;font-size:15px;margin-bottom:12px;">
        <span>Total</span><span>{{ cart.total_price | money }}</span>
      </div>
    {% endif %}
    <a href="{{ routes.cart_url }}" class="cart-checkout-btn">Ir al checkout →</a>
  </div>
</div>

{% schema %}
{ "name": "Header", "settings": [] }
{% endschema %}
