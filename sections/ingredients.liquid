<style>
#ingredients{background:var(--white)}
.cards-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
.ing-card{border:1px solid rgba(0,0,0,0.07);border-radius:16px;padding:28px 24px;background:var(--white);transition:box-shadow 0.25s,transform 0.2s;display:flex;flex-direction:row;align-items:flex-end;justify-content:space-between;gap:16px;min-height:150px;overflow:hidden}
.ing-card:hover{box-shadow:0 10px 36px rgba(10,89,69,0.12);transform:translateY(-2px)}
.card-text{flex:1;display:flex;flex-direction:column;gap:6px;align-self:flex-start}
.ing-card h3{font-family:var(--font-display);font-size:clamp(17px,2vw,21px);line-height:1.25;color:var(--black);font-weight:400}
.compound-value{font-size:13px;font-weight:500;color:var(--green);opacity:.85}
.card-visual{width:84px;height:84px;flex-shrink:0;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:44px;align-self:flex-end;background:var(--cream)}
.card-visual svg{width:54px;height:54px;opacity:.85}
@media(max-width:768px){.cards-grid{grid-template-columns:1fr}.ing-card{min-height:120px}.card-visual{width:70px;height:70px;font-size:36px}}
</style>

<section id="ingredients" class="section">
  <div class="section-inner">
    <div class="section-header">
      <h2>Cada Ingrediente Rigurosamente Elegido</h2>
      <p>Cada componente dentro de nuestra entrega semanal tiene un único propósito: llegar al centro operativo de tu negocio donde la información superficial de las redes sociales no puede ayudar.</p>
    </div>
    <div class="cards-grid">
      <div class="ing-card">
        <div class="card-text"><h3>Flujos de Trabajo Semanales</h3><span class="compound-value">Automatización de Procesos</span></div>
        <div class="card-visual"><svg viewBox="0 0 64 64" fill="none"><circle cx="20" cy="20" r="10" stroke="#0a5945" stroke-width="3"/><circle cx="44" cy="44" r="10" stroke="#0a5945" stroke-width="3"/><path d="M28 24L36 40" stroke="#6d388b" stroke-width="2.5" stroke-linecap="round"/><circle cx="20" cy="20" r="4" fill="#0a5945"/><circle cx="44" cy="44" r="4" fill="#0a5945"/></svg></div>
      </div>
      <div class="ing-card">
        <div class="card-text"><h3>Tutoriales de 5 Minutos</h3><span class="compound-value">Lógica de Ejecución Inmediata</span></div>
        <div class="card-visual"><svg viewBox="0 0 64 64" fill="none"><circle cx="32" cy="32" r="24" stroke="#0a5945" stroke-width="3"/><path d="M32 16L32 32L44 40" stroke="#6d388b" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><circle cx="32" cy="32" r="3" fill="#0a5945"/></svg></div>
      </div>
      <div class="ing-card">
        <div class="card-text"><h3>Prompts Listos para Copiar</h3><span class="compound-value">Entrada de Datos Optimizada</span></div>
        <div class="card-visual"><svg viewBox="0 0 64 64" fill="none"><rect x="8" y="12" width="48" height="40" rx="6" stroke="#0a5945" stroke-width="3"/><path d="M18 26h28M18 34h20" stroke="#6d388b" stroke-width="2.5" stroke-linecap="round"/><circle cx="46" cy="42" r="4" fill="#0a5945"/></svg></div>
      </div>
      <div class="ing-card">
        <div class="card-text"><h3>Ácidos Esenciales</h3><span class="compound-value">Soporte Estructural</span></div>
        <div class="card-visual"><svg viewBox="0 0 64 64" fill="none"><path d="M12 48Q20 28 32 32Q44 36 52 16" stroke="#0a5945" stroke-width="3" stroke-linecap="round"/><circle cx="12" cy="48" r="4" fill="#0a5945"/><circle cx="32" cy="32" r="4" fill="#6d388b"/><circle cx="52" cy="16" r="4" fill="#0a5945"/></svg></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Ingredients", "settings": [] }
{% endschema %}
