<style>
#comparison{background:var(--cream)}
.table-wrapper{overflow-x:auto;border-radius:16px;box-shadow:0 4px 32px rgba(0,0,0,.08)}
table{width:100%;border-collapse:collapse;background:var(--white);border-radius:16px;overflow:hidden}
thead th{padding:20px 24px;font-size:13px;font-weight:700;letter-spacing:.04em;text-align:center}
thead th:first-child{text-align:left;background:var(--white);color:var(--black);font-size:12px;text-transform:uppercase;letter-spacing:.06em}
.th-others{background:#f5f5f5;color:#888;font-size:12px;letter-spacing:.06em;text-transform:uppercase}
.th-us{background:var(--green);color:var(--white);font-size:14px}
tbody tr{border-top:1px solid var(--border)}
tbody tr:hover{background:#fafafa}
tbody td{padding:18px 24px;font-size:14px;color:var(--black)}
tbody td:first-child{font-weight:600}
tbody td:not(:first-child){text-align:center}
.check{color:var(--success);font-size:20px}
.cross{color:#ccc;font-size:20px}
.cell-detail{font-size:12px;color:var(--muted);display:block;font-weight:400;margin-top:2px}
@media(max-width:768px){.table-wrapper{border-radius:10px}tbody td{padding:14px;font-size:12px}thead th{padding:12px;font-size:11px}}
</style>

<section id="comparison" class="section">
  <div class="section-inner">
    <div class="section-header"><h2>¿Por qué elegir AI with Remy?</h2><p>No todos los boletines de IA son iguales. Aquí está la diferencia real.</p></div>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Característica</th>
            <th class="th-others">Otros Boletines</th>
            <th class="th-us">AI with Remy ✦</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Potencia de los Prompts<span class="cell-detail">Calidad y especificidad</span></td><td><span class="cross">✗</span><br><small style="color:#aaa;font-size:11px;">Fórmulas vagas</small></td><td><span class="check">✓</span><br><small style="color:var(--success);font-size:11px;">Ingeniería con variables</small></td></tr>
          <tr><td>Velocidad de Absorción<span class="cell-detail">Tiempo para aplicar</span></td><td><span class="cross">✗</span><br><small style="color:#aaa;font-size:11px;">20 min de lectura</small></td><td><span class="check">✓</span><br><small style="color:var(--success);font-size:11px;">Tutoriales de 5 min</small></td></tr>
          <tr><td>Validación de Información<span class="cell-detail">Fuente y verificación</span></td><td><span class="cross">✗</span><br><small style="color:#aaa;font-size:11px;">Hype de foros</small></td><td><span class="check">✓</span><br><small style="color:var(--success);font-size:11px;">Probado en producción</small></td></tr>
          <tr><td>Contenido Práctico<span class="cell-detail">Aplicabilidad directa</span></td><td><span class="cross">✗</span><br><small style="color:#aaa;font-size:11px;">Noticias macro</small></td><td><span class="check">✓</span><br><small style="color:var(--success);font-size:11px;">Flujos copiar y pegar</small></td></tr>
          <tr><td>Libre de Relleno<span class="cell-detail">Densidad de valor</span></td><td><span class="cross">✗</span><br><small style="color:#aaa;font-size:11px;">Patrocinios ocultos</small></td><td><span class="check">✓</span><br><small style="color:var(--success);font-size:11px;">100% contenido puro</small></td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Comparison Table", "settings": [] }
{% endschema %}
