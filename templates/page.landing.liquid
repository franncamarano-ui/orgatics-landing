{% layout none %}
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI with Remy — La Fórmula Semanal que Domina los Flujos de Trabajo con IA</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green:      #0a5945;
      --green-light:#0d7a60;
      --purple:     #6d388b;
      --cream:      #f5f1eb;
      --cream-dark: #ede8e0;
      --black:      #121212;
      --black-soft: #1a1a1a;
      --success:    #00b67a;
      --white:      #ffffff;
      --border:     #dbdbdb;
      --muted:      #6b6b6b;
      --font-display: 'DM Serif Display', Georgia, serif;
      --font-body:    'DM Sans', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-body);
      color: var(--black);
      background: var(--white);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* ── ANNOUNCEMENT BAR ── */
    .announce-bar {
      background: var(--green);
      color: var(--white);
      text-align: center;
      padding: 10px 16px;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.02em;
    }
    .announce-bar a { color: var(--white); text-decoration: underline; text-underline-offset: 3px; }

    /* ── NAVBAR ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--white);
      border-bottom: 1px solid var(--border);
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      padding: 0 5%;
      height: 64px;
      gap: 16px;
    }
    .nav-left {
      display: flex;
      align-items: center;
      gap: 0;
    }
    .nav-logo {
      font-family: var(--font-display);
      font-size: 22px;
      color: var(--green);
      text-decoration: none;
      letter-spacing: -0.01em;
      justify-self: center;
      white-space: nowrap;
    }
    .nav-right {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 4px;
    }
    .nav-links {
      display: flex;
      gap: 4px;
      list-style: none;
      align-items: center;
    }
    .nav-links a {
      font-size: 14px;
      font-weight: 500;
      color: var(--black);
      text-decoration: none;
      opacity: 0.72;
      transition: opacity 0.2s;
      padding: 6px 12px;
      border-radius: 6px;
    }
    .nav-links a:hover { opacity: 1; background: #f5f5f5; }
    .nav-cta {
      background: var(--green) !important;
      color: var(--white) !important;
      padding: 8px 18px !important;
      border-radius: 6px;
      font-size: 13px !important;
      font-weight: 600 !important;
      letter-spacing: 0.04em;
      opacity: 1 !important;
      transition: background 0.2s !important;
    }
    .nav-cta:hover { background: var(--green-light) !important; }
    .nav-icon-btn {
      width: 40px;
      height: 40px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--white);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s, border-color 0.2s;
      position: relative;
    }
    .nav-icon-btn:hover { background: var(--cream); border-color: #bbb; }
    .nav-icon-btn svg { width: 18px; height: 18px; stroke: var(--black); stroke-width: 2; fill: none; stroke-linecap: round; stroke-linejoin: round; }
    .cart-count {
      position: absolute;
      top: -5px;
      right: -5px;
      width: 17px;
      height: 17px;
      background: var(--green);
      color: var(--white);
      border-radius: 50%;
      font-size: 10px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid var(--white);
    }
    /* Search dropdown */
    .search-wrapper { position: relative; }
    .search-dropdown {
      display: none;
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      width: 300px;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 12px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.12);
      padding: 12px;
      z-index: 200;
    }
    .search-dropdown.open { display: block; }
    .search-dropdown input {
      width: 100%;
      border: 1.5px solid var(--border);
      border-radius: 8px;
      padding: 10px 14px;
      font-family: var(--font-body);
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s;
    }
    .search-dropdown input:focus { border-color: var(--green); }
    /* Cart drawer */
    .cart-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.35);
      z-index: 300;
    }
    .cart-overlay.open { display: block; }
    .cart-drawer {
      position: fixed;
      top: 0;
      right: -400px;
      width: 360px;
      height: 100vh;
      background: var(--white);
      box-shadow: -8px 0 40px rgba(0,0,0,0.15);
      z-index: 301;
      display: flex;
      flex-direction: column;
      transition: right 0.3s cubic-bezier(0.4,0,0.2,1);
      padding: 0;
    }
    .cart-drawer.open { right: 0; }
    .cart-drawer-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 24px;
      border-bottom: 1px solid var(--border);
    }
    .cart-drawer-header h3 { font-family: var(--font-display); font-size: 18px; }
    .cart-close {
      width: 32px; height: 32px;
      border: none; background: #f5f5f5;
      border-radius: 6px; cursor: pointer;
      font-size: 16px; display: flex; align-items: center; justify-content: center;
      transition: background 0.2s;
    }
    .cart-close:hover { background: #ebebeb; }
    .cart-drawer-body {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 12px;
      padding: 32px;
      color: var(--muted);
    }
    .cart-drawer-body .empty-icon { font-size: 48px; opacity: 0.4; }
    .cart-drawer-body p { font-size: 14px; text-align: center; line-height: 1.6; }
    .cart-drawer-footer { padding: 20px 24px; border-top: 1px solid var(--border); }
    .cart-checkout-btn {
      width: 100%;
      background: var(--green);
      color: var(--white);
      border: none;
      border-radius: 8px;
      padding: 14px;
      font-family: var(--font-body);
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      opacity: 0.5;
      transition: opacity 0.2s;
    }
    .nav-hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
    .nav-hamburger span { display: block; width: 22px; height: 2px; background: var(--black); border-radius: 2px; }

    /* ── HERO ── */
    #hero {
      background: var(--cream);
      padding: 72px 5% 80px;
    }
    .hero-inner {
      max-width: 1120px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1.1fr;
      gap: 64px;
      align-items: center;
    }
    .hero-visual {
      position: relative;
      border-radius: 20px;
      overflow: hidden;
      background: linear-gradient(145deg, var(--green) 0%, #0d6b51 40%, #1a8b6a 70%, #a8d5c5 100%);
      aspect-ratio: 4/5;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 40px 32px;
      box-shadow: 0 24px 60px rgba(10,89,69,0.25);
    }
    .hero-visual::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .newsletter-card {
      position: relative;
      z-index: 1;
      background: rgba(255,255,255,0.97);
      border-radius: 14px;
      padding: 32px 28px;
      width: 100%;
      max-width: 340px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    }
    .newsletter-card .issue-badge {
      display: inline-block;
      background: var(--green);
      color: var(--white);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 20px;
      margin-bottom: 14px;
    }
    .newsletter-card h3 {
      font-family: var(--font-display);
      font-size: 18px;
      line-height: 1.35;
      color: var(--black);
      margin-bottom: 12px;
    }
    .newsletter-card .divider { height: 1px; background: var(--border); margin: 14px 0; }
    .newsletter-card .item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 10px;
    }
    .newsletter-card .item-dot {
      width: 6px;
      height: 6px;
      background: var(--green);
      border-radius: 50%;
      margin-top: 7px;
      flex-shrink: 0;
    }
    .newsletter-card .item p { font-size: 12px; color: var(--muted); line-height: 1.5; }
    .newsletter-card .item strong { font-size: 12px; color: var(--black); font-weight: 600; display: block; }
    .hero-sub-badge {
      position: absolute;
      bottom: 28px;
      right: -12px;
      background: var(--white);
      border-radius: 50px;
      padding: 10px 18px 10px 14px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.15);
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      font-weight: 600;
      color: var(--black);
    }
    .hero-sub-badge .avatars { display: flex; }
    .hero-sub-badge .avatars span {
      width: 26px; height: 26px;
      border-radius: 50%;
      border: 2px solid var(--white);
      margin-left: -8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px;
      font-weight: 700;
      color: var(--white);
    }
    .hero-sub-badge .avatars span:first-child { margin-left: 0; background: #e57373; }
    .hero-sub-badge .avatars span:nth-child(2) { background: #64b5f6; }
    .hero-sub-badge .avatars span:nth-child(3) { background: #81c784; }

    .hero-copy { display: flex; flex-direction: column; gap: 24px; }
    .hero-copy .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--green);
    }
    .hero-copy .eyebrow::before {
      content: '';
      display: inline-block;
      width: 24px;
      height: 2px;
      background: var(--green);
    }
    .hero-copy h1 {
      font-family: var(--font-display);
      font-size: clamp(28px, 3.5vw, 44px);
      line-height: 1.2;
      color: var(--black);
      letter-spacing: -0.02em;
    }
    .underline-purple {
      position: relative;
      display: inline;
      white-space: nowrap;
    }
    .underline-purple::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 100%;
      height: 3px;
      background: var(--purple);
      border-radius: 2px;
    }
    .hero-copy p {
      font-size: 16px;
      color: #444;
      line-height: 1.7;
      max-width: 480px;
    }
    .hero-form { display: flex; flex-direction: column; gap: 10px; }
    .hero-form .input-row {
      display: flex;
      gap: 0;
      border: 1.5px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      background: var(--white);
      transition: border-color 0.2s;
    }
    .hero-form .input-row:focus-within { border-color: var(--green); }
    .hero-form input {
      flex: 1;
      border: none;
      outline: none;
      padding: 14px 16px;
      font-family: var(--font-body);
      font-size: 14px;
      color: var(--black);
      background: transparent;
    }
    .hero-form button {
      background: var(--green);
      color: var(--white);
      border: none;
      padding: 14px 20px;
      font-family: var(--font-body);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.05em;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.2s;
    }
    .hero-form button:hover { background: var(--green-light); }
    .hero-form .micro-copy {
      font-size: 12px;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .hero-form .micro-copy::before {
      content: '🔒';
      font-size: 11px;
    }

    /* ── SECTION WRAPPER ── */
    .section { padding: 88px 5%; }
    .section-inner { max-width: 1120px; margin: 0 auto; }
    .section-header { text-align: center; max-width: 680px; margin: 0 auto 56px; }
    .section-header h2 {
      font-family: var(--font-display);
      font-size: clamp(26px, 3vw, 38px);
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
    }
    .section-header p { font-size: 15px; color: #555; line-height: 1.7; }

    /* ── COMPONENTS GRID ── */
    #components { background: var(--cream); }
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
    .card {
      border: 1px solid rgba(0,0,0,0.07);
      border-radius: 16px;
      padding: 28px 24px 24px 28px;
      background: var(--white);
      transition: box-shadow 0.25s, transform 0.2s;
      display: flex;
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 16px;
      min-height: 160px;
      overflow: hidden;
      position: relative;
    }
    .card:hover { box-shadow: 0 10px 36px rgba(10,89,69,0.12); transform: translateY(-2px); }
    .card-text { flex: 1; display: flex; flex-direction: column; gap: 6px; align-self: flex-start; }
    .card h3 {
      font-family: var(--font-display);
      font-size: clamp(18px, 2vw, 22px);
      line-height: 1.25;
      color: var(--black);
      font-weight: 400;
    }
    .card .compound-value {
      font-size: 13px;
      font-weight: 500;
      color: var(--green);
      opacity: 0.85;
    }
    .card-visual {
      width: 88px;
      height: 88px;
      flex-shrink: 0;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 48px;
      align-self: flex-end;
      background: var(--cream);
      position: relative;
      overflow: hidden;
    }
    .card-visual svg {
      width: 56px;
      height: 56px;
      opacity: 0.85;
    }

    /* ── WHAT SETS APART ── */
    #differentiators { background: var(--cream); }
    .split-layout {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 72px;
      align-items: center;
    }
    .split-visual {
      border-radius: 20px;
      overflow: hidden;
      aspect-ratio: 1;
      background: linear-gradient(160deg, var(--green) 0%, #0d6b51 50%, #c8e6c9 100%);
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .split-visual .visual-inner {
      text-align: center;
      color: var(--white);
      z-index: 1;
    }
    .split-visual .visual-inner .big-r {
      font-family: var(--font-display);
      font-size: 120px;
      line-height: 1;
      opacity: 0.15;
      font-style: italic;
    }
    .split-visual .visual-inner .label {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: rgba(255,255,255,0.15);
      padding: 8px 20px;
      border-radius: 50px;
      backdrop-filter: blur(4px);
    }
    .split-visual::after {
      content: '';
      position: absolute;
      width: 200px;
      height: 200px;
      border-radius: 50%;
      background: rgba(255,255,255,0.06);
      top: -40px;
      right: -40px;
    }
    .diff-content { display: flex; flex-direction: column; gap: 0; }
    .diff-content h2 {
      font-family: var(--font-display);
      font-size: clamp(24px, 2.8vw, 36px);
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-bottom: 36px;
    }
    .diff-item { padding: 24px 0; border-bottom: 1px solid var(--border); }
    .diff-item:first-of-type { padding-top: 0; }
    .diff-item:last-of-type { border-bottom: none; }
    .diff-item h4 {
      font-size: 15px;
      font-weight: 700;
      color: var(--green);
      margin-bottom: 8px;
      letter-spacing: 0.01em;
    }
    .diff-item p { font-size: 14px; color: #555; line-height: 1.75; }

    /* ── TESTIMONIALS ── */
    #testimonials { background: var(--white); }
    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .testimonial-card {
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 28px 24px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      background: var(--white);
      transition: box-shadow 0.25s;
    }
    .testimonial-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.08); }
    .stars { display: flex; gap: 2px; }
    .stars span { font-size: 16px; }
    .testimonial-card blockquote {
      font-size: 14px;
      line-height: 1.75;
      color: #333;
      flex: 1;
      font-style: italic;
    }
    .testimonial-footer { display: flex; align-items: center; gap: 12px; padding-top: 16px; border-top: 1px solid var(--border); }
    .avatar-circle {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      font-weight: 700;
      color: var(--white);
      flex-shrink: 0;
    }
    .testimonial-meta { flex: 1; }
    .testimonial-meta strong { display: block; font-size: 14px; font-weight: 700; color: var(--black); }
    .testimonial-meta span { font-size: 12px; color: var(--muted); }
    .avatar-photo { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; flex-shrink: 0; border: 2px solid var(--border); }
    .verified-badge {
      font-size: 11px;
      font-weight: 600;
      color: var(--success);
      display: flex;
      align-items: center;
      gap: 3px;
      white-space: nowrap;
    }

    /* ── COMPARISON TABLE ── */
    #comparison { background: var(--cream); }
    .table-wrapper { overflow-x: auto; border-radius: 16px; box-shadow: 0 4px 32px rgba(0,0,0,0.08); }
    table { width: 100%; border-collapse: collapse; background: var(--white); border-radius: 16px; overflow: hidden; }
    thead th {
      padding: 20px 24px;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-align: center;
    }
    thead th:first-child { text-align: left; background: var(--white); color: var(--black); font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; }
    .th-others { background: #f5f5f5; color: #888; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; }
    .th-us { background: var(--green); color: var(--white); font-size: 14px; }
    tbody tr { border-top: 1px solid var(--border); }
    tbody tr:hover { background: #fafafa; }
    tbody td { padding: 18px 24px; font-size: 14px; color: var(--black); }
    tbody td:first-child { font-weight: 600; }
    tbody td:not(:first-child) { text-align: center; }
    .check { color: var(--success); font-size: 20px; }
    .cross { color: #ccc; font-size: 20px; }
    .cell-detail { font-size: 12px; color: var(--muted); display: block; font-weight: 400; margin-top: 2px; }

    /* ── GUARANTEE ── */
    #guarantee { background: var(--white); text-align: center; }
    .guarantee-badge {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
      border: 2px solid var(--border);
      border-radius: 24px;
      padding: 56px 72px;
      max-width: 680px;
      margin: 0 auto;
      position: relative;
    }
    .guarantee-badge::before {
      content: '';
      position: absolute;
      inset: -2px;
      border-radius: 24px;
      background: linear-gradient(135deg, var(--green), var(--purple));
      z-index: -1;
    }
    .guarantee-badge::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 22px;
      background: var(--white);
      z-index: -1;
    }
    .shield-icon {
      width: 80px;
      height: 80px;
      background: var(--cream);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 36px;
    }
